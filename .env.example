# Copy to .env and fill with real values. NEVER commit the real .env.
# Production secrets must be injected via the VPS secret store / encrypted env, not committed.

# --- Supabase (client-safe anon/publishable values) ---
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# --- Supabase server-only (NEVER expose to client) ---
SUPABASE_SERVICE_ROLE_KEY="server-side-only-service-role-key"

# --- Stripe ---
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_or_live_publishable_key"
STRIPE_SECRET_KEY="sk_test_or_live_secret_key"        # SECRET — server only
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"  # SECRET — server only

# --- Payments client token ---
VITE_PAYMENTS_CLIENT_TOKEN="test_or_live_client_token"
